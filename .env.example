# ============================================================
# SZABLON ZMIENNYCH ŚRODOWISKOWYCH
# ============================================================
# Skopiuj ten plik jako ".env" lokalnie (do testów) i NIGDY go nie commituj.
# Na Railway: wklej te zmienne w panelu "Variables" Twojego serwisu.
# Plik .env.example (ten plik) jest bezpieczny do trzymania w publicznym repo,
# bo nie zawiera prawdziwych wartości — tylko nazwy zmiennych i przykłady.
# ============================================================

# --- DYSKORD: PODSTAWOWE DANE BOTA ---
# Discord Developer Portal -> Twoja aplikacja -> General Information / Bot
DISCORD_PUBLIC_KEY=wklej_tutaj_public_key
DISCORD_BOT_TOKEN=wklej_tutaj_bot_token

# --- TWOJE ID DISCORD (tylko Ty masz dostęp do /pomoc i /pomoc_urlop) ---
BOT_OWNER_ID=419910833112350720

# --- KONFIGURACJA SERWERÓW (webhooki, role, kanały, arkusz Google Sheets) ---
# JEDEN zminifikowany JSON, klucz = ID serwera (guild_id), wartość = config tego serwera.
# WAŻNE: musi być w jednej linii, poprawny JSON (podwójne cytaty, bez przecinka na końcu).
# Przykład poniżej zawiera DWA serwery (skopiuj/rozbuduj wzór dla kolejnych).
#
# GOOGLE_SHEET_WEBHOOK_URL jest OPCJONALNY per serwer — każdy serwer może mieć WŁASNY arkusz
# (np. inną organizację/frakcję z innym Google Sheets). Jeśli serwer nie ma tego pola,
# bot po prostu nie zapisze dla niego wpisów /urlop i /szkolenie do żadnego arkusza (zobaczysz o tym ostrzeżenie w logach startowych).
#
# Żeby wygenerować swój JSON wygodnie: zrób to w edytorze kodu / online JSON minifier,
# a potem wklej wynik jako WARTOŚĆ tej jednej zmiennej (Railway przyjmuje długie wartości bez problemu).
SERVER_CONFIGS_JSON={"ID_SERWERA_1":{"REQUIRED_ROLE_IDS":["ID_ROLI_ADMIN_1","ID_ROLI_ADMIN_2"],"PING_ROLE_ID":"ID_ROLI_DO_PINGOWANIA","WEBHOOK_URL":"https://discord.com/api/webhooks/.../...","GOOGLE_SHEET_WEBHOOK_URL":"https://script.google.com/macros/s/deployment_id_serwera_1/exec","CHANNELS":{"AWANS":"ID_KANALU","DEGRADACJA":"ID_KANALU","ZAWIESZENIE":"ID_KANALU","ZAGROZENIE":"ID_KANALU","SZKOLENIE":"ID_KANALU","URLOP":"ID_KANALU","ZWOLNIENIA":"ID_KANALU","NAGANA":"ID_KANALU","KARY":"ID_KANALU","ZEBRANIE":"ID_KANALU"}},"ID_SERWERA_2":{"REQUIRED_ROLE_IDS":["ID_ROLI_ADMIN_1"],"PING_ROLE_ID":"ID_ROLI_DO_PINGOWANIA","WEBHOOK_URL":"https://discord.com/api/webhooks/.../...","GOOGLE_SHEET_WEBHOOK_URL":"https://script.google.com/macros/s/deployment_id_serwera_2/exec","CHANNELS":{"AWANS":"ID_KANALU","DEGRADACJA":"ID_KANALU","ZAWIESZENIE":"ID_KANALU","ZAGROZENIE":"ID_KANALU","SZKOLENIE":"ID_KANALU","URLOP":"ID_KANALU","ZWOLNIENIA":"ID_KANALU","NAGANA":"ID_KANALU","KARY":"ID_KANALU","ZEBRANIE":"ID_KANALU"}}}

# --- LOG AKTUALIZACJI Z GITHUB (opcjonalne, ale rekomendowane) ---
GITHUB_REPO=twoj-user/discord-faction-bot
GITHUB_BRANCH=main
# GITHUB_TOKEN nie jest wymagany dla repo publicznego — ustaw tylko jeśli trafiasz na limit 60 zapytań/h.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- PORT (Railway ustawia to automatycznie, nie musisz dotykać) ---
# PORT=3000
